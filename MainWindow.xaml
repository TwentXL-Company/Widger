<Window x:Class="Widger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Widger"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/" 
        xmlns:comp="clr-namespace:Widger.Components"
        Icon="/Assets/Images/icon.png"
        WindowStyle="None"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        MinHeight="450" MinWidth="500"
        Title="MainWindow" Height="650" Width="900">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                  CornerRadius="0"
                  CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}" CornerRadius="0" BorderBrush="{DynamicResource ButtonColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{DynamicResource TitleBar}" MouseDown="Titlebar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image Source="/Assets/Images/icon.png" Height="20" Margin="0,0,5,0" />
                    <Label Foreground="#FFFFFF">widger</Label>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2">
                    <Button x:Name="ButtonMinimize" Width="40" Style="{DynamicResource TitleBar_Button}" Click="ButtonMinimize_Click">
                        <Image Style="{DynamicResource Title_Minimize}"/>
                    </Button>
                    <Button x:Name="ButtonMaximize" Width="40" Style="{DynamicResource TitleBar_Button}" Click="ButtonMaximize_Click">
                        <Image Style="{DynamicResource Title_Maximize}"/>
                    </Button>
                    <Button x:Name="ButtonClose" Width="40" Style="{DynamicResource TitleBar_Button}" Click="ButtonClose_Click">
                        <Image Style="{DynamicResource Title_Close}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="30" Cursor="">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Cursor="">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <svgc:SvgViewbox Grid.Column="0" Source="Assets/Images/logo_widger.svg" Width="100" HorizontalAlignment="Left" />

                    <Button x:Name="BurgerMenu" Grid.Column="1" HorizontalAlignment="Right" Style="{DynamicResource Burger}" Click="BurgerMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Settings" Click="Settings_Click" />
                                <MenuItem Header="About app" Click="AboutApp_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="+ Create new widget" HorizontalAlignment="Left" VerticalAlignment="Center" Click="CreateWidget_Click" Cursor="Hand" />

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="WidgetsContent" Orientation="Vertical" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <comp:Toast Grid.Row="1" x:Name="MyToast" Padding="10" />
            <Grid Grid.Row="1" x:Name="Modal_Content" />
        </Grid>
    </Border>
</Window>
