<UserControl x:Class="Widger.Components.Modal_Settings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Widger.Components"
             mc:Ignorable="d" 
             d:Background="{DynamicResource WindowBackground}"
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
        <Label Style="{DynamicResource LabelHeading}" Margin="0,0,0,20">Settings</Label>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Label Margin="0,0,5,0">Dark theme: </Label>
            <Button Style="{DynamicResource Button_Link}" Content="On" />
        </StackPanel>

        <Button HorizontalAlignment="Left" Content="Close" Click="Close_Click" Margin="0,50,0,0" />
    </StackPanel>
</UserControl>
