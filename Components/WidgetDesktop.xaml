<Window x:Class="Widger.Components.WidgetDesktop"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Title="WidgetDesktop" Height="170" Width="300">

    <Border x:Name="WidgetRoot" Style="{DynamicResource Widget}" MouseDown="WidgetDrag_MouseDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="25" />
            </Grid.RowDefinitions>

            <Label x:Name="Heading" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{DynamicResource LabelHeading}" Content="Heading" Margin="0,0,0,5"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="Content" TextWrapping="WrapWithOverflow" Text="Text" />
            </ScrollViewer>

            <StackPanel x:Name="ActionsPanel"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=WidgetRoot}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Button x:Name="MoreButton"
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Style="{DynamicResource Button_Link}"
                        Padding="6,0"
                        Content="⋯"
                        FontSize="24"
                        Click="MoreButton_Click">

                    <Button.ContextMenu>
                        <ContextMenu>
                            <!--<MenuItem Header="Edit">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Source="Assets/Images/pen.svg" Width="10" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Style">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Source="Assets/Images/style.svg" Width="10" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator/>-->

                            <MenuItem Header="Delete from desktop" Foreground="{DynamicResource ErrorColor}" Click="DeleteFromDesktop_Click">
                                <MenuItem.Icon>
                                    <svgc:SvgViewbox Source="Assets/Images/trash.svg" Width="10" />
                                </MenuItem.Icon>
                            </MenuItem>

                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>

            <Label Grid.Row="2" Padding="0" x:Name="WidgetDate" Foreground="{DynamicResource TextColor_Secondary}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Content="05.05.2025" FontSize="10"/>
        </Grid>
    </Border>
</Window>