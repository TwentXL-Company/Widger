<UserControl x:Class="Widger.Components.Widget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Widger.Components"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/" 
             mc:Ignorable="d" 
             d:Background="{DynamicResource WindowBackground}"
             d:DesignHeight="450" d:DesignWidth="800"
>

    <Border x:Name="MainBorder" Style="{DynamicResource Widget}" Width="300" Height="170">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="25" />
            </Grid.RowDefinitions>

            <Label x:Name="Heading" Grid.Row="0"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Style="{DynamicResource LabelHeading}"
                   Content="Heading" Margin="0,0,0,5" />
            <TextBox x:Name="HeadingEdited" Grid.Row="0" FontWeight="Bold" FontSize="16"
                    HorizontalAlignment="Stretch" VerticalAlignment="Center" Style="{DynamicResource TextBoxSkeleton}"
                    Text="Heading" Margin="0,0,0,5"/>
            <svgc:SvgViewbox x:Name="WidgetIsDesktop" Grid.Row="0" Source="Assets/Images/addDesktop.svg" Height="15" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Collapsed" />

            <ScrollViewer x:Name="ScrollContent" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="Content" TextWrapping="WrapWithOverflow" Text="Text" />
            </ScrollViewer>
            <ScrollViewer x:Name="ScrollContentEdited" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="ContentEdited" TextWrapping="WrapWithOverflow" Text="Text" AcceptsReturn="True" VerticalContentAlignment="Top" Style="{DynamicResource TextBoxSkeleton}" />
            </ScrollViewer>

            <Button x:Name="MoreButton"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{DynamicResource Button_Link}"
                    Padding="6,0"
                    Content="⋯"
                    FontSize="24"
                    Click="MoreButton_Click">

                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Edit" Click="Edit_Click">
                            <MenuItem.Icon>
                                <svgc:SvgViewbox Source="Assets/Images/pen.svg" Width="10" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Style" Click="Style_Click">
                            <MenuItem.Icon>
                                <svgc:SvgViewbox Source="Assets/Images/style.svg" Width="10" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Add to desktop" Click="AddToDesktop_Click">
                            <MenuItem.Icon>
                                <svgc:SvgViewbox Source="Assets/Images/addDesktop.svg" Width="10" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator/>

                        <MenuItem Header="Delete" Foreground="{DynamicResource ErrorColor}" Click="DeleteWidget_Click">
                            <MenuItem.Icon>
                                <svgc:SvgViewbox Source="Assets/Images/trash.svg" Width="10" />
                            </MenuItem.Icon>
                        </MenuItem>

                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <Button x:Name="SaveChangesButton" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{DynamicResource Button_Link}" Content="Save changes" Click="SaveChanges_Click" Cursor="Hand" />

            <Label Grid.Row="2" Padding="0"
                   x:Name="WidgetDate"
                   Foreground="{DynamicResource TextColor_Secondary}"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Content="05.05.2025" FontSize="10"/>
        </Grid>
    </Border>
</UserControl>